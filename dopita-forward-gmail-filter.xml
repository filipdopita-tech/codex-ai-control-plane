<?xml version='1.0' encoding='UTF-8'?>
<feed xmlns='http://www.w3.org/2005/Atom' xmlns:apps='http://schemas.google.com/apps/2006'>
  <title>Mail Filters</title>
  <id>tag:mail.google.com,2008:filters:dopita-oneflow-forward</id>
  <updated>2026-05-04T18:50:00Z</updated>
  <author>
    <name>Filip Dopita</name>
    <email>filipdopit@gmail.com</email>
  </author>

  <!-- Filter 1: maily s recipient dopita@oneflow.cz nikdy do spamu (forwardy) -->
  <entry>
    <category term='filter'></category>
    <title>Mail Filter</title>
    <content></content>
    <apps:property name='to' value='dopita@oneflow.cz'/>
    <apps:property name='shouldNeverSpam' value='true'/>
    <apps:property name='sizeOperator' value='s_sl'/>
    <apps:property name='sizeUnit' value='s_smb'/>
  </entry>

  <!-- Filter 2: maily s envelope from SRS0=*@oneflow.cz (přepsaný forwardem) -->
  <entry>
    <category term='filter'></category>
    <title>Mail Filter</title>
    <content></content>
    <apps:property name='from' value='SRS0='/>
    <apps:property name='shouldNeverSpam' value='true'/>
    <apps:property name='sizeOperator' value='s_sl'/>
    <apps:property name='sizeUnit' value='s_smb'/>
  </entry>

  <!-- Filter 3: maily s @oneflow.cz envelope sender nikdy do spamu (vlastní doména) -->
  <entry>
    <category term='filter'></category>
    <title>Mail Filter</title>
    <content></content>
    <apps:property name='from' value='@oneflow.cz'/>
    <apps:property name='shouldNeverSpam' value='true'/>
    <apps:property name='sizeOperator' value='s_sl'/>
    <apps:property name='sizeUnit' value='s_smb'/>
  </entry>

</feed>
